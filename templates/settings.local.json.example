{
  "_comment": "Example project-level overrides for ~/.claude/settings.json. Copy to .claude/settings.local.json in a project root and prune to needs. This example implements rule 06 (destructive actions) + security.md §1.2 (least privilege) as a deny-list starting point for non-technical users.",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:github.com)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git checkout:*)",
      "Bash(npm test)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(pytest:*)",
      "Bash(ruff check:*)",
      "Bash(mypy:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore --:*)",
      "Bash(git branch -D:*)",
      "Bash(:(){:|:&};:)",
      "Bash(sudo:*)",
      "Bash(doas:*)",
      "Bash(chmod 777:*)",
      "Bash(chown:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(systemctl:*)",
      "Bash(service:*)",
      "Bash(init:*)",
      "Bash(killall:*)",
      "Bash(pkill -9:*)",
      "Bash(kill -9 1:*)",
      "Bash(crontab:*)",
      "Bash(at:*)",
      "Bash(batch:*)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(eval:*)",
      "Bash(source /dev/stdin:*)",
      "Bash(cat .env)",
      "Bash(cat .env.*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat ~/.ssh/id_*)",
      "Bash(cat ~/.aws/credentials)",
      "Bash(cat ~/.config/gh/hosts.yml)",
      "Bash(echo * >> ~/.ssh/authorized_keys)",
      "Bash(echo * >> ~/.bashrc)",
      "Bash(echo * >> ~/.zshrc)",
      "Bash(echo * >> ~/.profile)",
      "Bash(DROP TABLE:*)",
      "Bash(DELETE FROM:*)",
      "Bash(TRUNCATE:*)",
      "Bash(psql * -c DROP:*)",
      "Bash(mysql * -e DROP:*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(*.pem)",
      "Write(*.key)",
      "Write(~/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(~/.gnupg/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(*.pem)",
      "Edit(*.key)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)"
    ]
  }
}
