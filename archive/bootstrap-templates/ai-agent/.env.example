# LLM Provider
OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Agent Settings
AGENT_MODEL=gpt-4o-mini
AGENT_TEMPERATURE=0
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true

# Optional: LangSmith tracing
# LANGCHAIN_TRACING_V2=true
