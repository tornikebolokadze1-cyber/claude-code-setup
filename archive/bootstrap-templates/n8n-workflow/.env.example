# n8n Instance Configuration
# Copy this file to .env and fill in your values

# Your n8n instance URL (no trailing slash)
N8N_INSTANCE_URL=https://aipulsegeorgia2025.app.n8n.cloud

# n8n API key (Settings > API > Create API Key)
N8N_API_KEY=your-api-key-here

# Optional: Webhook base URL (if different from instance URL)
# N8N_WEBHOOK_URL=https://aipulsegeorgia2025.app.n8n.cloud/webhook

# Optional: Backup directory for workflow exports
# BACKUP_DIR=./backups
