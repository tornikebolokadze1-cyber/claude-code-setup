# ===========================================
# Application Configuration
# ===========================================
APP_NAME=hybrid-app
APP_URL=http://localhost:3000
PORT=3000
NODE_ENV=development

# ===========================================
# n8n Configuration
# ===========================================
# n8n cloud instance URL (no trailing slash)
N8N_INSTANCE_URL=https://aipulsegeorgia2025.app.n8n.cloud

# n8n API key (Settings > API > Create API Key)
N8N_API_KEY=

# ===========================================
# Webhook Security
# ===========================================
# Shared secret for webhook authentication (both directions)
# Generate with: openssl rand -hex 32
WEBHOOK_SHARED_SECRET=

# ===========================================
# Database (add as needed)
# ===========================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# ===========================================
# External Services (add as needed)
# ===========================================
# SENDGRID_API_KEY=
# SLACK_WEBHOOK_URL=
# STRIPE_SECRET_KEY=
