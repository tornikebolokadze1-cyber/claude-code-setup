# .env.example — claude-code-setup template repo
#
# This template repo itself does NOT require any runtime secrets.
# This file exists as a reference for the env vars that CONSUMING projects
# commonly need.
#
# Each bootstrap template ships its own .env.example under:
#   bootstrap-templates/<template-name>/.env.example
#
# Copy the relevant .env.example to your project root and fill in real values.
# NEVER commit a .env file containing real secrets.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here          # https://console.anthropic.com/

# ── Supabase (nextjs-webapp, express-backend) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-key-here   # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-key-here  # Keep server-side only — never expose to browser

# ── Database (fastapi-backend, express-backend) ────────────────────────────────
DATABASE_URL=your-key-here               # e.g. postgresql://user:pass@host:5432/db

# ── n8n (hybrid-code-n8n) ────────────────────────────────────────────────────
N8N_API_KEY=your-key-here                # https://docs.n8n.io/api/authentication/

# ── Telegram (telegram-bot) ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-key-here         # Obtain from @BotFather on Telegram
